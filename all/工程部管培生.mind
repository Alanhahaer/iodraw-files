{"root":{"data":{"id":"djabu88nyxc0","created":1781598160949,"text":"工程部管培生","background":"#0070c0"},"children":[{"data":{"id":"djabupksqoo0","created":1781598198688,"text":"品牌与客户"},"children":[{"data":{"id":"djacizg9s7k0","created":1781600100922,"text":"品牌"},"children":[{"data":{"id":"djacj2elug80","created":1781600107352,"text":"Coach"},"children":[]},{"data":{"id":"djacj7t0hcw0","created":1781600119107,"text":"Tory Burch"},"children":[]},{"data":{"id":"djacjb9cphs0","created":1781600126625,"text":"Michael Kors"},"children":[]},{"data":{"id":"djf8m0phosw0","created":1782096854092,"text":"Tapestry"},"children":[]},{"data":{"id":"djf8m9vt30g0","created":1782096874065,"text":"Calvin Klein"},"children":[]},{"data":{"id":"djf8mfk160g0","created":1782096886414,"text":"Charles Keith"},"children":[]}]}]},{"data":{"id":"djaburn3qns0","created":1781598203181,"text":"责任观念与态度","layout_mind_offset":{"x":113.99999645352388,"y":111.99999666213995},"expandState":"expand"},"children":[{"data":{"id":"djabuy7a7e80","created":1781598217462,"text":"与品牌客户沟通的指引","layout_right_offset":{"x":17.999999463558424,"y":4.9999998509882175},"expandState":"expand","priority":null},"children":[{"data":{"id":"djac1blvidk0","created":1781598716827,"text":"沟通方式"},"children":[{"data":{"id":"djac1dw2cbk0","created":1781598721797,"text":"正式书面记录（电子邮件，信件等）","layout_right_offset":{"x":559.9999833107001,"y":16.999999493360633}},"children":[{"data":{"id":"djacawp5hl40","created":1781599468015,"text":"发送前应由工程部经理或助理经理审查批准"},"children":[]},{"data":{"id":"djacb9e9w0g0","created":1781599495656,"text":"需要发送或抄送给品牌的报告须发送给生产品牌商品的工厂得到批准"},"children":[]}]},{"data":{"id":"djac22aqk480","created":1781598774927,"text":"电话或通讯软件"},"children":[{"data":{"id":"djacc3k9t880","created":1781599561322,"text":"避免做出确认的决定"},"children":[]},{"data":{"id":"djacckg6p0w0","created":1781599598080,"text":"建议面对面或电子邮件沟通，不涉及品牌，避免产生误会"},"children":[]}]},{"data":{"id":"djac27f5zjc0","created":1781598786079,"text":"面对面"},"children":[{"data":{"id":"djacd0r8v6o0","created":1781599633577,"text":"避免做出确认的决定，官方建议通过电子邮件确认"},"children":[]}]}]},{"data":{"id":"djac2ehxzy80","created":1781598801484,"text":"指南"},"children":[{"data":{"id":"djac2ghvjpk0","created":1781598805834,"text":"依据SOP和培训手册进行回应"},"children":[]},{"data":{"id":"djac5qlvo7k0","created":1781599062936,"text":"每次技术支援都应向上报告"},"children":[]},{"data":{"id":"djac60b1jew0","created":1781599084048,"text":"回应和决定只与技术相关，换货、价格等应提交至相应的销售代表，并向上级报告"},"children":[]},{"data":{"id":"djac6wran0g0","created":1781599154688,"text":"质量相关问题谨慎回复客户，向销售代表、上级以及质量保证部门汇报"},"children":[]}]}]},{"data":{"id":"djac09daqbc0","created":1781598633591,"text":"跟工厂做审核服务的指引","layout_right_offset":{"x":19.999999403953552,"y":-0.9999999701976776},"priority":null},"children":[{"data":{"id":"djac5beios00","created":1781599029839,"text":"根据审核表上的项目进行审核，不在表上的项目写在备注上。"},"children":[]},{"data":{"id":"djace6acz2w0","created":1781599723981,"text":"审核后与工厂举行总结会议，如有品牌QC参与更好。"},"children":[]},{"data":{"id":"djacey2ane80","created":1781599784443,"text":"审核报告要简单且直截了当，报告应该发送工程部经理或助理经理复查批准再发送"},"children":[]},{"data":{"id":"djacfrfepf40","created":1781599848363,"text":"审核高高发送品牌前序发送生产品牌商品的工厂确认"},"children":[]}]},{"data":{"id":"djac0dyasbk0","created":1781598643568,"text":"保密性","layout_right_offset":{"x":23.999999284744206,"y":12.999999612569866},"priority":null,"layout_left_offset":{"x":42.000000000000114,"y":5.684341886080802e-14}},"children":[{"data":{"id":"djacg72omps0","created":1781599882422,"text":"部门内部文件不得透露任何人"},"children":[]},{"data":{"id":"djacgc7kec00","created":1781599893601,"text":"特定品牌的文件不透露给不生产特定品牌商品的工厂"},"children":[]},{"data":{"id":"djacgpny7kg0","created":1781599922890,"text":"客户提供的敏感信息谨慎对待，未经许可不得泄露给其他方"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}