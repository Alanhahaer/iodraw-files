{"root":{"data":{"id":"dja9pzt68vs0","created":1781592186922,"text":"边缘涂装（Edge Coating）","background":"#0070c0","expandState":"expand"},"children":[{"data":{"id":"dja9s7ewz0o0","created":1781592360202,"text":"涂料（Paint）","expandState":"expand"},"children":[{"data":{"id":"dja9sfo8bw80","created":1781592378180,"text":"黏合剂（Adhesion Promoter）","expandState":"expand"},"children":[{"data":{"id":"dja9t0bsdcw0","created":1781592423140,"text":"用途","expandState":"expand"},"children":[{"data":{"id":"djacwbrme2w0","created":1781601146464,"text":"提升剥离强度"},"children":[]}]},{"data":{"id":"dja9t5e27z40","created":1781592434161,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9t80nc2o0","created":1781592439880,"text":"成分","expandState":"expand"},"children":[{"data":{"id":"djb0l5na0i00","created":1781667977773,"text":"？待学习"},"children":[]}]},{"data":{"id":"dja9z9ztr940","created":1781592914369,"text":"例子","expandState":"expand"},"children":[{"data":{"id":"dja9zcg8lx40","created":1781592919715,"text":"UA400H（粘合性）\nUA500H（易渗透）\nUA406H\nUA109（油性，气味大，不好操作）","expandState":"expand","layout_right_offset":{"x":57.49999742954992,"y":116.24999480322015}},"children":[]},{"data":{"id":"djg1gapnq7k0","created":1782178217873,"text":"COHA871","layout_right_offset":{"x":44.99999798834324,"y":-18.749999161809683}},"children":[]}]}]},{"data":{"id":"dja9simp7ns0","created":1781592384617,"text":"底油（Primer）","expandState":"expand","layout_right_offset":{"x":24.999998882413138,"y":31.24999860301608}},"children":[{"data":{"id":"dja9tcwsfow0","created":1781592450531,"text":"用途","expandState":"expand"},"children":[]},{"data":{"id":"dja9tl6lqhs0","created":1781592468539,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9tmgiwrk0","created":1781592471315,"text":"成分","expandState":"expand"},"children":[{"data":{"id":"djb0lb6wqvk0","created":1781667989843,"text":"PU-based"},"children":[]}]},{"data":{"id":"dja9zhcwcdc0","created":1781592930397,"text":"例子","expandState":"expand","layout_right_offset":{"x":1.1368683772161603e-13,"y":11.249999497085724}},"children":[{"data":{"id":"dja9zk3kz480","created":1781592936364,"text":"DA550\nDP5/C","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dja9sn9c4jc0","created":1781592394693,"text":"色油（边油）（Edge Paint）","expandState":"expand","layout":null,"layout_right_offset":{"x":29.999998658895436,"y":82.49999631196283}},"children":[{"data":{"id":"dja9tryhf3s0","created":1781592483285,"text":"用途","expandState":"expand","layout":null},"children":[{"data":{"id":"djacwvf9zl40","created":1781601189253,"text":"给皮边上色，形成均匀饱满的有色膜层"},"children":[]}]},{"data":{"id":"dja9ttg01y00","created":1781592486521,"text":"样式","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9tv0dst40","created":1781592489930,"text":"成分","expandState":"expand","layout":null},"children":[{"data":{"id":"djb0lm9z8ew0","created":1781668013974,"text":"PU-based"},"children":[]}]},{"data":{"id":"dja9zozx1gg0","created":1781592947026,"text":"例子","expandState":"expand","layout":null},"children":[{"data":{"id":"dja9zqvxb3s0","created":1781592951139,"text":"DAM660\nDAS660\nDAH630\nDES123","expandState":"expand","layout":null},"children":[]}]}]},{"data":{"id":"djg1fdwstmo0","created":1782178146471,"text":"防爆油","layout_right_offset":{"x":36.249998379498834,"y":91.24999592080724}},"children":[{"data":{"id":"djg1fmlt1w80","created":1782178165397,"text":"用途"},"children":[]},{"data":{"id":"djg1fpnashk0","created":1782178172018,"text":"样式"},"children":[]},{"data":{"id":"djg1fqy6xi80","created":1782178174853,"text":"成分"},"children":[]},{"data":{"id":"djg1fsqng0g0","created":1782178178751,"text":"例子"},"children":[{"data":{"id":"djg1fudvwaw0","created":1782178182332,"text":"CA226（中光防爆油）\nCOHS602（中光防爆油）"},"children":[]}]}]},{"data":{"id":"djabprig3540","created":1781597811078,"text":"存储","layout_right_offset":{"x":11.24999949708581,"y":109.99999508261715}},"children":[{"data":{"id":"djabptuptgw0","created":1781597816174,"text":"底油与边油","layout_right_offset":{"x":9.999999552965164,"y":26.24999882653367}},"children":[]}]}]},{"data":{"id":"djaa0fj98280","created":1781593004792,"text":"操作程序（Operation Procedure）","layout_mind_offset":{"x":140.9999997466805,"y":153.24999608471984},"expandState":"expand"},"children":[{"data":{"id":"djaa3yp8rew0","created":1781593281605,"text":"一般流程（对于皮边厚度≤3mm）","layout_right_offset":{"x":71.75001020356956,"y":-54.499997667968614},"expandState":"expand"},"children":[{"data":{"id":"djaa79ewfiw0","created":1781593540017,"text":"黏合剂（apply adhesion promoter）→底油（apply 1st primer）→打磨（buff）→底油（apply 2nd primer）→打磨（buff）→色油（apply 1st colored edge paint）→色油（apply 2nd colored edge paint）","layout_right_offset":{"x":126.75001018866863,"y":2.750000905245315},"expandState":"expand"},"children":[]}]},{"data":{"id":"djg0dn70ja80","created":1782175188841,"text":"判断边油是否干透的方法","layout_right_offset":{"x":48.749997820705175,"y":-2.499999888241234}},"children":[{"data":{"id":"djg0e4oj4v40","created":1782175226906,"text":"方法1：砂纸测试"},"children":[{"data":{"id":"djg0giwtysg0","created":1782175414611,"text":"用#240号砂纸在边油表面轻轻用手打磨，如果打磨中所产生的尘粉是粉末状，代表边油干透"},"children":[]}]},{"data":{"id":"djg0g9ykiqw0","created":1782175395125,"text":"方法2：湿度检测仪测试"},"children":[{"data":{"id":"djg10dxjpbk0","created":1782176971053,"text":"使用湿度检测仪测试边油的表面，如果测试仪显示11-12%或更低，则表示边油干透"},"children":[]}]}]}]},{"data":{"id":"djab5ceqvqw0","created":1781596210920,"text":"工具","layout_mind_offset":{"x":-49.99999776482582,"y":6.249999720603228},"expandState":"expand"},"children":[{"data":{"id":"djaakzgae680","created":1781594615432,"text":"油边工具","expandState":"expand","layout_left_offset":{"x":-34.999998435378075,"y":11.249999497085838}},"children":[{"data":{"id":"djaala3vkn40","created":1781594638626,"text":"油轮","layout_right_offset":{"x":39.99999821186054,"y":-12.499999441206342},"layout_left_offset":{"x":-5.9999998211861225,"y":-62.999998122453746}},"children":[{"data":{"id":"djaao2xep6o0","created":1781594858090,"text":"粗齿轮油轮用于底油，幼齿轮邮轮用于粘合促进剂及色油\n（号码#越大，齿轮越幼）","layout_right_offset":{"x":41.24999815598119,"y":-18.749999161809797},"layout_left_offset":{"x":-20.99999937415123,"y":-25.999999225139675}},"children":[{"data":{"id":"djaaqh4p8k00","created":1781595045734,"text":"原因"},"children":[{"data":{"id":"djaaqmg7up40","created":1781595057314,"text":"幼细的油斗可以帮助减少饱和滴油的问题"},"children":[]}]}]}]},{"data":{"id":"djaau25cms00","created":1781595326578,"text":"双边自动油边机","layout_right_offset":{"x":26.249998826533556,"y":6.249999720603341},"layout_left_offset":{"x":-64.99999806284916,"y":-37.99999886751169}},"children":[{"data":{"id":"djab1lyjaqo0","created":1781595918251,"text":"建议速度：3-4"},"children":[]}]},{"data":{"id":"djb0ffgl1xk0","created":1781667528951,"text":"直式油边机（两边）","layout_left_offset":{"x":-130.99999609589588,"y":-40.99999877810484},"expandState":"expand"},"children":[{"data":{"id":"djb0div2beg0","created":1781667379628,"text":"1、边油倒入两旁的油缸\n2、将皮条放入中间，然后慢慢地将底部接回\n3、将皮条晾干","layout_left_offset":{"x":-109.99999672174465,"y":24.999999254941883}},"children":[]}]},{"data":{"id":"djaazkwjt540","created":1781595759226,"text":"自动型油盒","layout_right_offset":{"x":63.749997150153064,"y":27.4999987706542},"layout_left_offset":{"x":-63.999998092651424,"y":12.999999612569923}},"children":[{"data":{"id":"djaazuhwte80","created":1781595780108,"text":"建议不要使用胶油轮，改用金属油轮"},"children":[]},{"data":{"id":"djab07u1t7c0","created":1781595809140,"text":"油轮滚动速度不要太快，容易导致很多气泡"},"children":[]},{"data":{"id":"djab0vmfd7c0","created":1781595860922,"text":"建议速度\n底油：3-4\n色油：2-3"},"children":[]}]},{"data":{"id":"djay223xvn40","created":1781660838934,"text":"自动油边机（电动油边机）工序","layout_left_offset":{"x":-142.49999407678888,"y":17.249999169260377}},"children":[{"data":{"id":"djay2b1449k0","created":1781660858354,"text":"1、将边油倒入油缸\n2、盖上挡板\n3、调整挡板和油边轮之间的宽度来控制油量\n4、去除泡泡\n5、拉动皮条涂上边油","layout_left_offset":{"x":-47.499997876584644,"y":-8.749999608844519}},"children":[]}]},{"data":{"id":"djb0gr653qw0","created":1781667632805,"text":"全自动边油调色","layout_left_offset":{"x":-56.999998301267624,"y":182.9999945461753}},"children":[{"data":{"id":"djb0ia4pyig0","created":1781667752442,"text":"1、测色仪读取颜色\n2、分析及生成配方\n3、调色机按配方加入颜料\n4、搅拌均匀并检查颜色，继续调整直至颜色相符","layout_left_offset":{"x":-212.99999089539097,"y":1.4999995455147825}},"children":[]}]},{"data":{"id":"djb0s2h72q00","created":1781668519423,"text":"加入助剂","layout_left_offset":{"x":-87.49999608844519,"y":168.7499924562872},"expandState":"expand"},"children":[{"data":{"id":"djb0sr425mo0","created":1781668573049,"text":"1、确保宽口桶干净\n2、将边油完全倒入一宽口桶\n3、取适量的增稠剂（0.05-0.1%，按要求浓度调整）\n4、取适量消泡剂（0.1-0.5%）\n5、再取适量的纯净水（1-3%）\n6、用搅拌机或一专用棍子顺一方向边搅拌边慢慢加入\n7、搅拌3-5分钟，静置2小时后再使用","layout_left_offset":{"x":-544.9999796599158,"y":-69.99998834729257}},"children":[]}]},{"data":{"id":"djab23qczyg0","created":1781595956938,"text":"备注","layout_right_offset":{"x":47.499997876584644,"y":33.74999849125754},"layout_left_offset":{"x":-260.2499905116863,"y":-117.2499957419933},"progress":1},"children":[{"data":{"id":"djab2a254co0","created":1781595970712,"text":"由于不同工厂的工具来自不同的供应厂商，参数应根据具体情况设定。","layout_right_offset":{"x":39.999998211860714,"y":0},"layout_left_offset":{"x":-56.000000327825546,"y":-2.2500008083881085}},"children":[]}]}]},{"data":{"id":"djab6faylfk0","created":1781596295585,"text":"打磨工具","layout_left_offset":{"x":-241.49999075382988,"y":192.49999400228285}},"children":[{"data":{"id":"djab6onrreg0","created":1781596315951,"text":"皮毯轮（Leather and felt flap wheel）","layout_left_offset":{"x":-128.74999424442672,"y":-67.49999698251497}},"children":[]},{"data":{"id":"djab7hj3nls0","created":1781596378795,"text":"毛毯轮（Felt wheel）","layout_left_offset":{"x":-221.24999010935454,"y":2.499999888241291}},"children":[]},{"data":{"id":"djab80e3hgg0","created":1781596419852,"text":"纤维轮（Fiber wheel）","layout_left_offset":{"x":-212.49999050050997,"y":57.499997429549694}},"children":[]},{"data":{"id":"djab8noiac80","created":1781596470547,"text":"羊毛轮（wool wheel） ","layout_left_offset":{"x":-249.99998882412945,"y":113.74999491497897}},"children":[]},{"data":{"id":"djabeyfwvxc0","created":1781596964157,"text":"#120打磨石轮","layout_left_offset":{"x":-266.2499880976979,"y":161.2499927915636}},"children":[]},{"data":{"id":"djabf5h0li00","created":1781596979461,"text":"装上砂纸的软砂轮","layout_left_offset":{"x":-289.9999870359902,"y":196.24999256804608}},"children":[]},{"data":{"id":"djabfjkotfc0","created":1781597010158,"text":"装上砂纸的砂轮","layout_left_offset":{"x":-282.49998737126646,"y":232.4999896064404}},"children":[]},{"data":{"id":"djabggjwtlk0","created":1781597081945,"text":"注意事项","layout_left_offset":{"x":-251.2499887682502,"y":292.4999869242314}},"children":[{"data":{"id":"djabgwhel4o0","created":1781597116622,"text":"打磨轮须保持良好状态，必要时更换。"},"children":[]},{"data":{"id":"djabh6h4u000","created":1781597138373,"text":"保持打磨轮清洁，打磨后用微湿毛巾擦干净打磨轮，因为残留的灰尘会沾到边油上。"},"children":[]}]}]},{"data":{"id":"djabio75j8o0","created":1781597255316,"text":"烘干工具","layout_left_offset":{"x":-103.9999960064888,"y":409.9999750256539}},"children":[{"data":{"id":"djabiv7uzi00","created":1781597270596,"text":"流水线输送带烘干机"},"children":[]},{"data":{"id":"djabizvd58w0","created":1781597280725,"text":"自动旋转式烘干机"},"children":[]},{"data":{"id":"djabj65bmaw0","created":1781597294387,"text":"发热头移动式烘干机","layout_left_offset":{"x":-7.49999966472393,"y":13.7499993853271}},"children":[]},{"data":{"id":"djabjkt50680","created":1781597326303,"text":"高空吊篮运输带","layout_left_offset":{"x":-18.749999161809683,"y":36.00000804662693}},"children":[]},{"data":{"id":"djabjrawdrs0","created":1781597340437,"text":"焗炉/烤箱","layout_left_offset":{"x":-55.999997287988776,"y":100.99999557435513}},"children":[{"data":{"id":"djabknxmn9s0","created":1781597411469,"text":"没有时间控制，难把控时间，容易过度烘干"},"children":[]}]},{"data":{"id":"djabm3qutio0","created":1781597524252,"text":"注意事项","layout_left_offset":{"x":-0.9999992996455376,"y":159.49999304860864}},"children":[{"data":{"id":"djabm9bjpi80","created":1781597536387,"text":"温度调到45-50℃，过高会产生气泡，甚至造成黏合问题"},"children":[]},{"data":{"id":"djabmtcroq80","created":1781597579996,"text":"烘干机内理想湿度应低于20%","layout_left_offset":{"x":-41.249998155981416,"y":3.749999832361823}},"children":[]},{"data":{"id":"djabn7azxfs0","created":1781597610364,"text":"定期检查烘干机内实际温度和预设温度是否相同","layout_left_offset":{"x":-27.499998770654315,"y":11.249999497085582}},"children":[]},{"data":{"id":"djabnhd7c5s0","created":1781597632266,"text":"烘干机内实际温湿度满足最佳温度和湿度时，烘干时间约为20分钟。（根据具体设备而定）","layout_left_offset":{"x":-7.499999664723873,"y":18.749999161809683}},"children":[]}]}]}]},{"data":{"id":"djb65cyi3340","created":1781683666521,"text":"皮革类型","layout_mind_offset":{"x":943.9999718666086,"y":220.000007390976}},"children":[{"data":{"id":"djb6kxu69340","created":1781684887435,"text":"人造革","expandState":"expand","layout_left_offset":{"x":-54.99999754130852,"y":4.999999776482582}},"children":[{"data":{"id":"djb6gupj8g00","created":1781684567167,"text":"PU皮（二代皮）","layout_left_offset":{"x":-135.9999959468842,"y":-11.999999642372131}},"children":[{"data":{"id":"djb6h8l4sjk0","created":1781684597376,"text":"以聚氨酯（PU, polyurethane）为原料制成的人造皮革","layout_left_offset":{"x":-13.249999660998697,"y":-15.749999772757292}},"children":[]}]},{"data":{"id":"djb6l9arulc0","created":1781684912383,"text":"PVC皮（一代皮）","layout_left_offset":{"x":-113.99999660253548,"y":-119.99999642372131}},"children":[]},{"data":{"id":"djb6lnyrrx40","created":1781684944309,"text":"超纤（超细纤维PU合成革）","layout_left_offset":{"x":-112.99999663233763,"y":29.74999935552478}},"children":[]}]},{"data":{"id":"djbqi9xedr40","created":1781741100857,"text":"真皮","layout_left_offset":{"x":-64.99999709427362,"y":126.24999435618543},"layout_right_offset":{"x":41.24999815598153,"y":28.749998714774847}},"children":[{"data":{"id":"djbqjqmb00w0","created":1781741215555,"text":"头层皮","layout_left_offset":{"x":-28.74999871477496,"y":-24.99999888241291}},"children":[]},{"data":{"id":"djbqjutzehs0","created":1781741224727,"text":"二层皮","layout_left_offset":{"x":-29.999998807907104,"y":59.999997317790985}},"children":[]}]},{"data":{"id":"djbqkal4uuo0","created":1781741259020,"text":"鞣制方式","layout_left_offset":{"x":-59.9999973177911,"y":282.4999873712661},"layout_right_offset":{"x":39.99999821186111,"y":68.74999692663584}},"children":[{"data":{"id":"djbqkkwie9c0","created":1781741281476,"text":"植鞣","layout_left_offset":{"x":-15.999999523162899,"y":0}},"children":[]},{"data":{"id":"djbqkp2f8uw0","created":1781741290540,"text":"铬鞣","layout_left_offset":{"x":-21.999999344348964,"y":33.99999898672104}},"children":[]}]}]}]},"template":"default","theme":"fresh-blue-compat","version":"1.4.43"}