{"root":{"data":{"id":"dja9pzt68vs0","created":1781592186922,"text":"边缘涂装（Edge Coating）","background":"#0070c0","expandState":"expand"},"children":[{"data":{"id":"dja9s7ewz0o0","created":1781592360202,"text":"涂料（Paint）","expandState":"expand"},"children":[{"data":{"id":"dja9sfo8bw80","created":1781592378180,"text":"黏合剂（Adhesion Promoter）","expandState":"expand"},"children":[{"data":{"id":"dja9t0bsdcw0","created":1781592423140,"text":"用途","expandState":"expand"},"children":[]},{"data":{"id":"dja9t5e27z40","created":1781592434161,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9t80nc2o0","created":1781592439880,"text":"成分","expandState":"expand"},"children":[]},{"data":{"id":"dja9z9ztr940","created":1781592914369,"text":"例子","expandState":"expand"},"children":[{"data":{"id":"dja9zcg8lx40","created":1781592919715,"text":"UA400H","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dja9simp7ns0","created":1781592384617,"text":"底油（Primer）","expandState":"expand"},"children":[{"data":{"id":"dja9tcwsfow0","created":1781592450531,"text":"用途","expandState":"expand"},"children":[]},{"data":{"id":"dja9tl6lqhs0","created":1781592468539,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9tmgiwrk0","created":1781592471315,"text":"成分","expandState":"expand"},"children":[]},{"data":{"id":"dja9zhcwcdc0","created":1781592930397,"text":"例子","expandState":"expand"},"children":[{"data":{"id":"dja9zk3kz480","created":1781592936364,"text":"DA550","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dja9sn9c4jc0","created":1781592394693,"text":"色油（边油）（Edge Paint）","expandState":"expand","layout":null},"children":[{"data":{"id":"dja9tryhf3s0","created":1781592483285,"text":"用途","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9ttg01y00","created":1781592486521,"text":"样式","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9tv0dst40","created":1781592489930,"text":"成分","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9zozx1gg0","created":1781592947026,"text":"例子","expandState":"expand","layout":null},"children":[{"data":{"id":"dja9zqvxb3s0","created":1781592951139,"text":"DAM660\nDAS660\nDAH630","expandState":"expand","layout":null},"children":[]}]}]}]},{"data":{"id":"djaa0fj98280","created":1781593004792,"text":"操作程序（Operation Procedure）","layout_mind_offset":{"x":534.7499833367772,"y":302.9999909698966},"expandState":"expand"},"children":[{"data":{"id":"djaa3yp8rew0","created":1781593281605,"text":"一般流程（对于皮边厚度≤3mm）","layout_right_offset":{"x":551.9999835491185,"y":-6.999999791383743},"expandState":"expand"},"children":[{"data":{"id":"djaa79ewfiw0","created":1781593540017,"text":"黏合剂（apply adhesion promoter）→底油（apply 1st primer）→打磨（buff）→底油（apply 2nd primer）→打磨（buff）→色油（apply 1st colored edge paint）→色油（apply 2nd colored edge paint）","layout_right_offset":{"x":1414.9999622106563,"y":-2.9999999105932034},"expandState":"expand"},"children":[]}]}]},{"data":{"id":"djaakzgae680","created":1781594615432,"text":"工具","layout_mind_offset":{"x":864.9999613314877,"y":650.2499751336885}},"children":[{"data":{"id":"djaala3vkn40","created":1781594638626,"text":"油轮","layout_right_offset":{"x":39.99999821186054,"y":-12.499999441206342}},"children":[{"data":{"id":"djaao2xep6o0","created":1781594858090,"text":"粗齿轮油轮用于底油，幼齿轮邮轮用于粘合促进剂及色油\n（号码#越大，齿轮越幼）","layout_right_offset":{"x":41.24999815598119,"y":-18.749999161809797}},"children":[{"data":{"id":"djaaqh4p8k00","created":1781595045734,"text":"原因"},"children":[{"data":{"id":"djaaqmg7up40","created":1781595057314,"text":"幼细的油斗可以帮助减少饱和滴油的问题"},"children":[]}]}]}]},{"data":{"id":"djaau25cms00","created":1781595326578,"text":"双边自动油边机","layout_right_offset":{"x":26.249998826533556,"y":6.249999720603341}},"children":[{"data":{"id":"djab1lyjaqo0","created":1781595918251,"text":"分支主题"},"children":[]}]},{"data":{"id":"djaazkwjt540","created":1781595759226,"text":"自动型油盒","layout_right_offset":{"x":21.24999905005103,"y":22.49999899417162}},"children":[{"data":{"id":"djaazuhwte80","created":1781595780108,"text":"建议不要使用胶油轮，改用金属油轮"},"children":[]},{"data":{"id":"djab07u1t7c0","created":1781595809140,"text":"油轮滚动速度不要太快，容易导致很多气泡"},"children":[]},{"data":{"id":"djab0vmfd7c0","created":1781595860922,"text":"建议速度\n底油：3-4\n色油：2-3"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue-compat","version":"1.4.43"}