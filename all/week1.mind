{"root":{"data":{"id":"dja9pzt68vs0","created":1781592186922,"text":"边缘涂装（Edge Coating）","background":"#0070c0","expandState":"expand"},"children":[{"data":{"id":"dja9s7ewz0o0","created":1781592360202,"text":"涂料（Paint）","expandState":"expand"},"children":[{"data":{"id":"dja9sfo8bw80","created":1781592378180,"text":"黏合剂（Adhesion Promoter）","expandState":"expand"},"children":[{"data":{"id":"dja9t0bsdcw0","created":1781592423140,"text":"用途","expandState":"expand"},"children":[]},{"data":{"id":"dja9t5e27z40","created":1781592434161,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9t80nc2o0","created":1781592439880,"text":"成分","expandState":"expand"},"children":[]},{"data":{"id":"dja9z9ztr940","created":1781592914369,"text":"例子","expandState":"expand"},"children":[{"data":{"id":"dja9zcg8lx40","created":1781592919715,"text":"UA400H","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dja9simp7ns0","created":1781592384617,"text":"底油（Primer）","expandState":"expand"},"children":[{"data":{"id":"dja9tcwsfow0","created":1781592450531,"text":"用途","expandState":"expand"},"children":[]},{"data":{"id":"dja9tl6lqhs0","created":1781592468539,"text":"样式","expandState":"expand"},"children":[]},{"data":{"id":"dja9tmgiwrk0","created":1781592471315,"text":"成分","expandState":"expand"},"children":[]},{"data":{"id":"dja9zhcwcdc0","created":1781592930397,"text":"例子","expandState":"expand"},"children":[{"data":{"id":"dja9zk3kz480","created":1781592936364,"text":"DA550","expandState":"expand"},"children":[]}]}]},{"data":{"id":"dja9sn9c4jc0","created":1781592394693,"text":"色油（边油）（Edge Paint）","expandState":"expand","layout":null},"children":[{"data":{"id":"dja9tryhf3s0","created":1781592483285,"text":"用途","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9ttg01y00","created":1781592486521,"text":"样式","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9tv0dst40","created":1781592489930,"text":"成分","expandState":"expand","layout":null},"children":[]},{"data":{"id":"dja9zozx1gg0","created":1781592947026,"text":"例子","expandState":"expand","layout":null},"children":[{"data":{"id":"dja9zqvxb3s0","created":1781592951139,"text":"DAM660\nDAS660\nDAH630","expandState":"expand","layout":null},"children":[]}]}]}]},{"data":{"id":"djaa0fj98280","created":1781593004792,"text":"操作程序（Operation Procedure）","layout_mind_offset":{"x":534.7499833367772,"y":302.9999909698966},"expandState":"expand"},"children":[{"data":{"id":"djaa3yp8rew0","created":1781593281605,"text":"一般流程（对于皮边厚度≤3mm）","layout_right_offset":{"x":551.9999835491185,"y":-6.999999791383743},"expandState":"expand"},"children":[{"data":{"id":"djaa79ewfiw0","created":1781593540017,"text":"黏合剂（apply adhesion promoter）→底油（apply 1st primer）→打磨（buff）→底油（apply 2nd primer）→打磨（buff）→色油（apply 1st colored edge paint）→色油（apply 2nd colored edge paint）","layout_right_offset":{"x":1414.9999622106563,"y":-2.9999999105932034},"expandState":"expand"},"children":[]}]}]},{"data":{"id":"djab5ceqvqw0","created":1781596210920,"text":"工具","layout_mind_offset":{"x":-49.99999776482582,"y":6.249999720603228},"expandState":"expand"},"children":[{"data":{"id":"djaakzgae680","created":1781594615432,"text":"油边工具","expandState":"expand","layout_left_offset":{"x":-34.999998435378075,"y":11.249999497085838}},"children":[{"data":{"id":"djaala3vkn40","created":1781594638626,"text":"油轮","layout_right_offset":{"x":39.99999821186054,"y":-12.499999441206342}},"children":[{"data":{"id":"djaao2xep6o0","created":1781594858090,"text":"粗齿轮油轮用于底油，幼齿轮邮轮用于粘合促进剂及色油\n（号码#越大，齿轮越幼）","layout_right_offset":{"x":41.24999815598119,"y":-18.749999161809797}},"children":[{"data":{"id":"djaaqh4p8k00","created":1781595045734,"text":"原因"},"children":[{"data":{"id":"djaaqmg7up40","created":1781595057314,"text":"幼细的油斗可以帮助减少饱和滴油的问题"},"children":[]}]}]}]},{"data":{"id":"djaau25cms00","created":1781595326578,"text":"双边自动油边机","layout_right_offset":{"x":26.249998826533556,"y":6.249999720603341}},"children":[{"data":{"id":"djab1lyjaqo0","created":1781595918251,"text":"建议速度：3-4"},"children":[]}]},{"data":{"id":"djaazkwjt540","created":1781595759226,"text":"自动型油盒","layout_right_offset":{"x":63.749997150153064,"y":27.4999987706542}},"children":[{"data":{"id":"djaazuhwte80","created":1781595780108,"text":"建议不要使用胶油轮，改用金属油轮"},"children":[]},{"data":{"id":"djab07u1t7c0","created":1781595809140,"text":"油轮滚动速度不要太快，容易导致很多气泡"},"children":[]},{"data":{"id":"djab0vmfd7c0","created":1781595860922,"text":"建议速度\n底油：3-4\n色油：2-3"},"children":[]}]},{"data":{"id":"djab23qczyg0","created":1781595956938,"text":"备注","layout_right_offset":{"x":47.499997876584644,"y":33.74999849125754}},"children":[{"data":{"id":"djab2a254co0","created":1781595970712,"text":"由于不同工厂的工具来自不同的供应厂商，参数应根据具体情况设定。","layout_right_offset":{"x":39.999998211860714,"y":0}},"children":[]}]}]},{"data":{"id":"djab6faylfk0","created":1781596295585,"text":"打磨工具","layout_left_offset":{"x":-29.99999865889555,"y":149.9999932944776}},"children":[{"data":{"id":"djab6onrreg0","created":1781596315951,"text":"皮毯轮（Leather and felt flap wheel）","layout_left_offset":{"x":-128.74999424442672,"y":-67.49999698251497}},"children":[]},{"data":{"id":"djab7hj3nls0","created":1781596378795,"text":"毛毯轮（Felt wheel）","layout_left_offset":{"x":-221.24999010935454,"y":2.499999888241291}},"children":[]},{"data":{"id":"djab80e3hgg0","created":1781596419852,"text":"纤维轮（Fiber wheel）","layout_left_offset":{"x":-212.49999050050997,"y":57.499997429549694}},"children":[]},{"data":{"id":"djab8noiac80","created":1781596470547,"text":"羊毛轮（wool wheel） ","layout_left_offset":{"x":-249.99998882412945,"y":113.74999491497897}},"children":[]},{"data":{"id":"djabeyfwvxc0","created":1781596964157,"text":"#120打磨石轮","layout_left_offset":{"x":-266.2499880976979,"y":161.2499927915636}},"children":[]},{"data":{"id":"djabf5h0li00","created":1781596979461,"text":"装上砂纸的软砂轮","layout_left_offset":{"x":-289.9999870359902,"y":196.24999256804608}},"children":[]},{"data":{"id":"djabfjkotfc0","created":1781597010158,"text":"装上砂纸的砂轮","layout_left_offset":{"x":-282.49998737126646,"y":232.4999896064404}},"children":[]},{"data":{"id":"djabggjwtlk0","created":1781597081945,"text":"注意事项","layout_left_offset":{"x":-251.2499887682502,"y":292.4999869242314}},"children":[{"data":{"id":"djabgwhel4o0","created":1781597116622,"text":"打磨轮须保持良好状态，必要时更换。"},"children":[]},{"data":{"id":"djabh6h4u000","created":1781597138373,"text":"保持打磨轮清洁，打磨后用微湿毛巾擦干净打磨轮，因为残留的灰尘会沾到边油上。"},"children":[]}]}]},{"data":{"id":"djabio75j8o0","created":1781597255316,"text":"烘干工具","layout_left_offset":{"x":-36.24999837949872,"y":577.499974183739}},"children":[{"data":{"id":"djabiv7uzi00","created":1781597270596,"text":"流水线输送带烘干机"},"children":[]},{"data":{"id":"djabizvd58w0","created":1781597280725,"text":"自动旋转式烘干机"},"children":[]},{"data":{"id":"djabj65bmaw0","created":1781597294387,"text":"发热头移动式烘干机","layout_left_offset":{"x":-7.49999966472393,"y":13.7499993853271}},"children":[]},{"data":{"id":"djabjkt50680","created":1781597326303,"text":"高空吊篮运输带","layout_left_offset":{"x":-21.24999905005103,"y":83.49999877065432}},"children":[]}]}]}]},"template":"default","theme":"fresh-blue-compat","version":"1.4.43"}